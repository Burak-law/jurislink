# ==============================================================
# JURISLINK ENVIRONMENT VARIABLES (TEMPLATE)
# ==============================================================

# NEXT_PUBLIC_SITE_URL: The URL of your application (e.g., https://jurislink.com)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# DATABASE_URL: The connection string for your production database.
# For SQLite (local): "file:./dev.db"
# For PostgreSQL (production): "postgresql://user:password@host:port/database"
DATABASE_URL="file:./dev.db"

# NEXTAUTH_URL: Required for NextAuth. Should match NEXT_PUBLIC_SITE_URL in production.
NEXTAUTH_URL="http://localhost:3000"

# NEXTAUTH_SECRET: Secret used to encrypt session tokens. Generate one using: openssl rand -base64 32
NEXTAUTH_SECRET="your_nextauth_secret_here"

# --------------------------------------------------------------
# EMAILS (Resend)
# --------------------------------------------------------------
RESEND_API_KEY="re_..."
NEXT_PUBLIC_RESEND_API_KEY="re_..."

# --------------------------------------------------------------
# SECURITY (Upstash Redis Rate Limiting)
# --------------------------------------------------------------
UPSTASH_REDIS_REST_URL="https://..."
UPSTASH_REDIS_REST_TOKEN="..."
